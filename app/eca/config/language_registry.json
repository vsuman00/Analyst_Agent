{
  "_comment": "Language Registry v1.0 — Add any new language here. Zero Python changes required.",
  "version": "1.0",

  "ignore_dirs": [
    "node_modules", ".git", "dist", "build", "__pycache__",
    ".venv", "venv", ".env", ".idea", ".vscode",
    "target", "out", "bin", "obj", ".gradle", ".mvn",
    "vendor", "Pods", ".dart_tool", ".pub-cache",
    "coverage", ".nyc_output", ".pytest_cache", "htmlcov"
  ],

  "universal_binary_extensions": [
    ".exe", ".dll", ".so", ".dylib", ".bin", ".out",
    ".png", ".jpg", ".jpeg", ".gif", ".ico", ".webp", ".bmp", ".tiff", ".svg",
    ".pdf", ".zip", ".tar", ".gz", ".7z", ".rar", ".bz2", ".xz",
    ".mp3", ".mp4", ".avi", ".mov", ".wav", ".ogg", ".flac",
    ".pyc", ".pyo", ".pyd", ".class", ".o", ".a",
    ".woff", ".woff2", ".eot", ".ttf", ".otf",
    ".db", ".sqlite", ".sqlite3",
    ".lock"
  ],

  "universal_config_extensions": [
    ".yaml", ".yml", ".toml", ".ini", ".cfg", ".conf",
    ".env", ".xml", ".properties"
  ],

  "universal_doc_extensions": [
    ".md", ".txt", ".rst", ".adoc", ".asciidoc",
    ".tex", ".latex", ".rtf"
  ],

  "languages": {

    "python": {
      "extensions": [".py", ".pyw", ".pyi"],
      "role": "backend",
      "entry_points": ["main.py", "app.py", "manage.py", "wsgi.py", "asgi.py", "server.py", "run.py"],
      "build_files": ["requirements.txt", "Pipfile", "pyproject.toml", "setup.py", "setup.cfg", "poetry.lock"],
      "binary": false,
      "notes": "CPython, PyPy"
    },

